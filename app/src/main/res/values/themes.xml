<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.DailyCompass" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#4CAF50</item>
        <item name="colorPrimaryVariant">#388E3C</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">#FF9800</item>
        <item name="colorSecondaryVariant">#F57C00</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
    </style>

    <!-- Стиль для полей ввода TextInputLayout -->
    <style name="CustomTextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">#1A000000</item>
        <item name="boxStrokeColor">#4CAF50</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="hintTextColor">#333333</item>
        <item name="android:textColorHint">#888888</item>
    </style>

    <!-- Стиль для выпадающего списка -->
    <style name="CustomExposedDropdownMenu" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxBackgroundColor">#1A000000</item>
        <item name="boxStrokeColor">#4CAF50</item>
        <item name="hintTextColor">#333333</item>
        <item name="android:textColorHint">#888888</item>
    </style>
</resources>