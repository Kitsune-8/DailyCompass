<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/photo_1"
        android:scaleType="centerCrop" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/overlay_white" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#4CAF50"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
            app:navigationIcon="?attr/homeAsUpIndicator"
            app:title="Добавление привычки"
            app:titleTextColor="#FFFFFF" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Название привычки -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/CustomTextInputLayout"
                    android:hint="Название привычки"
                    app:errorEnabled="true">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapSentences"
                        android:textColor="#333333"
                        android:focusable="true"
                        android:focusableInTouchMode="true" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Частота -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    style="@style/CustomExposedDropdownMenu"
                    android:hint="Частота">

                    <AutoCompleteTextView
                        android:id="@+id/actFrequency"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:text="Ежедневно"
                        android:textColor="#333333"
                        android:focusable="true"
                        android:focusableInTouchMode="true" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Время напоминания (только через диалог) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    style="@style/CustomTextInputLayout"
                    android:hint="Время напоминания (необязательно)">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etReminderTime"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:clickable="true"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:textColor="#333333"
                        android:cursorVisible="false" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Триггер-условие -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    style="@style/CustomTextInputLayout"
                    android:hint="Триггер-условие (необязательно)">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etTriggerCondition"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapSentences"
                        android:textColor="#333333"
                        android:focusable="true"
                        android:focusableInTouchMode="true" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Цвет привычки -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Цвет привычки"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/colorContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingBottom="8dp" />

                <!-- Целевая периодичность -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Целевая периодичность"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/rgTargetDays"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/rb7Days"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="7 дней"
                        android:textColor="#333333"
                        android:checked="true" />

                    <RadioButton
                        android:id="@+id/rb21Days"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="21 день"
                        android:textColor="#333333" />

                    <RadioButton
                        android:id="@+id/rb100Days"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="100 дней"
                        android:textColor="#333333" />

                </RadioGroup>

                <!-- Кнопки -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <Button
                        android:id="@+id/btnCancel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="Отмена"
                        android:backgroundTint="#9E9E9E" />

                    <Button
                        android:id="@+id/btnSave"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="Сохранить"
                        android:backgroundTint="#4CAF50" />

                </LinearLayout>

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

</FrameLayout>